<Page
    x:Class="BMSMonitor.Views.CellViewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BMSMonitor.ViewModels"
    xmlns:conv="using:BMSMonitor.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:CellStateToBackgroundConverter x:Key="CellStateBgConverter"/>
        <conv:CellStateToBorderConverter     x:Key="CellStateBorderConverter"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolToVisConverter"/>
        <conv:TempToForegroundConverter      x:Key="TempToFgConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="20,16,20,32" Spacing="12">

            <!-- ══ CELL VOLTAGES ══════════════════════════════════════════ -->
            <TextBlock Text="{x:Bind Lang.Cell_SecVoltageSummary, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{x:Bind Lang.Com_Min, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.MinCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2"/>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{x:Bind Lang.Com_Max, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.MaxCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="3" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2"/>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{x:Bind Lang.Com_Avg, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.AvgCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <Border Grid.Column="5" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,2"/>
                    <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="3">
                        <TextBlock Text="{x:Bind Lang.Cell_DeltaLabel, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.DeltaText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Text="{x:Bind Lang.Cell_SecCellGrid, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <ItemsRepeater x:Name="CellRepeater"
                           ItemsSource="{x:Bind ViewModel.Cells, Mode=OneWay}"
                           ElementPrepared="CellRepeater_ElementPrepared">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        Orientation="Horizontal"
                        MinItemWidth="110" MinItemHeight="84"
                        MinColumnSpacing="8" MinRowSpacing="8"
                        MaximumRowsOrColumns="10"
                        ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:CellViewModel">
                        <Button Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Height="84"
                                MinHeight="84"
                                MaxHeight="84"
                                Tag="{x:Bind Index}"
                                Click="CellButton_Click">
                            <Border CornerRadius="6" Padding="10,8"
                                    VerticalAlignment="Stretch"
                                    BorderThickness="1.5"
                                    Background="{x:Bind State, Converter={StaticResource CellStateBgConverter}, Mode=OneWay}"
                                    BorderBrush="{x:Bind State, Converter={StaticResource CellStateBorderConverter}, Mode=OneWay}">
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Label}"
                                               FontSize="10" Opacity="0.55"
                                               FontWeight="SemiBold" CharacterSpacing="60"/>
                                    <TextBlock Text="{x:Bind VoltageText, Mode=OneWay}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="⚡ BAL"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="#FFFF8C00"
                                               Visibility="{x:Bind IsBalancing, Converter={StaticResource BoolToVisConverter}, Mode=OneWay}"/>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,2,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="#FF25C685"/>
                    <TextBlock Text="{x:Bind Lang.Cell_Normal, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="#FFFF8C00"/>
                    <TextBlock Text="{x:Bind Lang.Cell_Low, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="#FFDC3545"/>
                    <TextBlock Text="{x:Bind Lang.Cell_Undervoltage, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Fill="#FF6F42C1"/>
                    <TextBlock Text="{x:Bind Lang.Cell_Overvoltage, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="10" Foreground="#FFFF8C00" VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind Lang.Cell_Balancing, Mode=OneWay}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- ══ TEMPERATURES ══════════════════════════════════════════ -->
            <TextBlock Text="{x:Bind Lang.Cell_SecNtcReadings, Mode=OneWay}"
                       Style="{StaticResource SectionHeaderStyle}"
                       Margin="0,16,0,0"/>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Temperatures, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        Orientation="Horizontal"
                        MinItemWidth="200" MinItemHeight="120"
                        MinColumnSpacing="10" MinRowSpacing="10"
                        MaximumRowsOrColumns="5"
                        ItemsStretch="Fill"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:TempViewModel">
                        <Border CornerRadius="8" Padding="16,14" BorderThickness="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{x:Bind Label}" FontSize="11" Opacity="0.55"
                                           FontWeight="SemiBold" CharacterSpacing="80"/>
                                <TextBlock Text="{x:Bind TempText, Mode=OneWay}"
                                           FontSize="28" FontWeight="SemiBold"/>
                                <ProgressBar Value="{x:Bind TempRaw, Mode=OneWay}"
                                             Minimum="0" Maximum="80"
                                             Height="5" CornerRadius="2.5"/>
                                <TextBlock Text="10kΩ NTC thermistor" FontSize="11" Opacity="0.4"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Thresholds reference -->
            <Border Style="{StaticResource CardStyle}" Margin="0,4,0,0">
                <Grid ColumnSpacing="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Cell_Thresholds, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind Lang.Cell_ThreshWarn, Mode=OneWay}" FontSize="13"/>
                        <TextBlock Text="{x:Bind Lang.Cell_ThreshCutoff, Mode=OneWay}" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Cell_Legend, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FF25C685" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Lang.Cell_NormalDesc, Mode=OneWay}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FFFF8C00" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Lang.Cell_WarnDesc, Mode=OneWay}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FFDC3545" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Lang.Cell_CutoffDesc, Mode=OneWay}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
