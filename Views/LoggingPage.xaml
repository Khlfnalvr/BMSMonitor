<Page
    x:Class="BMSMonitor.Views.LoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BMSMonitor.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,16,20,24" Spacing="8" MaxWidth="760"
                    HorizontalAlignment="Center">

            <!-- ── STATUS ──────────────────────────────────────────────────── -->
            <TextBlock Text="LOGGING STATUS" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="STATE" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="StateText" Text="Idle"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Margin="0,4"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="SAMPLES" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="SampleText" Text="0"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="3" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}"
                            Margin="0,4"/>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="DURATION" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DurationText" Text="—"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── FILE SETTINGS ────────────────────────────────────────────── -->
            <TextBlock Text="FILE SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">

                    <!-- Folder row -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Folder"
                                   FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                        <TextBlock x:Name="FolderText" Grid.Column="1"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="BrowseBtn"
                                Grid.Column="2" Content="Browse…"
                                Click="BrowseFolder_Click"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Format row -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Format"
                                   FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                        <ComboBox x:Name="FormatBox"
                                  Grid.Column="1"
                                  HorizontalAlignment="Left" MinWidth="200"
                                  SelectionChanged="FormatBox_SelectionChanged">
                            <ComboBoxItem Content="CSV — comma-separated (.csv)"    IsSelected="True"/>
                            <ComboBoxItem Content="TSV — tab-separated (.tsv)"/>
                            <ComboBoxItem Content="Excel — workbook (.xlsx)"/>
                            <ComboBoxItem Content="JSON — array of objects (.json)"/>
                        </ComboBox>
                    </Grid>

                    <!-- Filename row -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Filename"
                                   FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                        <TextBox x:Name="FileNameBox"
                                 Grid.Column="1"
                                 PlaceholderText="auto-generated if left blank"
                                 FontSize="12"/>
                    </Grid>

                    <!-- Full path preview -->
                    <TextBlock x:Name="FullPathText"
                               FontSize="11" Opacity="0.45"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ── COLUMN SETTINGS ─────────────────────────────────────────── -->
            <TextBlock Text="COLUMN SETTINGS" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                               Text="Pilih kolom yang ingin di-log dan atur urutannya dengan drag ≡. Dikunci saat logging aktif."/>

                    <!-- Quick-select buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SelectAllBtn"   Content="Pilih Semua"   Click="SelectAll_Click"    FontSize="12" Padding="10,5"/>
                        <Button x:Name="DeselectAllBtn" Content="Hapus Semua"   Click="DeselectAll_Click"  FontSize="12" Padding="10,5"/>
                        <Button x:Name="ResetColsBtn"   Content="Reset Default" Click="ResetColumns_Click" FontSize="12" Padding="10,5"/>
                    </StackPanel>

                    <!-- Group toggles -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Grup:" FontSize="12" Opacity="0.55" VerticalAlignment="Center"/>
                        <Button x:Name="ToggleCellsBtn" Content="Cell Voltages" Click="ToggleCells_Click" FontSize="11" Padding="8,4"/>
                        <Button x:Name="ToggleBalBtn"   Content="Balancing"     Click="ToggleBal_Click"   FontSize="11" Padding="8,4"/>
                        <Button x:Name="ToggleTempBtn"  Content="Temperatures"  Click="ToggleTemp_Click"  FontSize="11" Padding="8,4"/>
                    </StackPanel>

                    <!-- Draggable / reorderable column list -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="6">
                        <ListView x:Name="ColumnListView"
                                  MaxHeight="300"
                                  CanReorderItems="True"
                                  CanDragItems="True"
                                  AllowDrop="True"
                                  SelectionMode="Single">
                            <ListView.Resources>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelected"            Color="Transparent"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{ThemeResource SubtleFillColorSecondaryBrush}"/>
                                <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed"     Color="{ThemeResource SubtleFillColorTertiaryBrush}"/>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding"                    Value="0"/>
                                    <Setter Property="MinHeight"                  Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LogColumn">
                                    <Grid Padding="10,5" ColumnSpacing="10" Background="Transparent">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="32"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Drag handle -->
                                        <TextBlock Grid.Column="0"
                                                   Text="&#xE784;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Opacity="0.3"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                        <!-- Column label -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Label}"
                                                   FontSize="12.5" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Group badge -->
                                        <Border Grid.Column="2"
                                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{x:Bind Group}"
                                                       FontSize="10" Opacity="0.55"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Enable checkbox -->
                                        <CheckBox Grid.Column="3"
                                                  IsChecked="{x:Bind IsEnabled, Mode=TwoWay}"
                                                  MinWidth="0" Padding="0" Margin="0"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── CONTROLS ────────────────────────────────────────────────── -->
            <TextBlock Text="CONTROLS" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="HintText"
                               Text="Connect to the ESP32 first, then start logging."
                               FontSize="12" Opacity="0.6" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="StartStopBtn"
                                Content="Start Logging"
                                Style="{ThemeResource AccentButtonStyle}"
                                MinWidth="140"
                                Click="StartStopBtn_Click"/>
                        <Button Content="Open Folder"
                                MinWidth="120"
                                Click="OpenFolderBtn_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ── DATA FORMAT ──────────────────────────────────────────────── -->
            <TextBlock Text="DATA FORMAT" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Text="Each row = one data frame received from the ESP32 (~1 Hz)."/>
                    <TextBlock FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Text="Fields: Timestamp · PackVoltage_V · SOC_pct · Current_A · Status · Cell1_V … Cell20_V · Bal1 … Bal20 · Temp1_C … Temp10_C"/>
                    <TextBlock FontSize="11" Opacity="0.45" TextWrapping="Wrap"
                               Text="CSV / TSV: streamed to disk every frame.  Excel / JSON: buffered in memory and written when you press Stop."/>
                </StackPanel>
            </Border>


            <!-- ── LIVE DATA STREAM ──────────────────────────────────────────── -->
            <TextBlock Text="LIVE DATA (20 TERBARU)" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}" Padding="0">
                <StackPanel>

                    <!-- Header row -->
                    <Grid Padding="14,9,14,7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="68"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="68"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TIMESTAMP"  Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="1" Text="SOC %"      Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="PACK V"     Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="3" Text="CURRENT A"  Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="4" Text="STATUS"     Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="5" Text="MIN CELL V" Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="6" Text="MAX CELL V" Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="7" Text="DELTA mV"   Style="{StaticResource StreamHeaderStyle}"/>
                        <TextBlock Grid.Column="8" Text="BAL CELLS"  Style="{StaticResource StreamHeaderStyle}"/>
                    </Grid>

                    <!-- Header separator -->
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="14,0"/>

                    <!-- Data rows — newest first -->
                    <ItemsControl x:Name="StreamTable"
                                  ItemsSource="{x:Bind ViewModel.DataStream}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:LogRow">
                                <Grid Padding="14,5,14,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="56"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="76"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="68"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind Timestamp}"   Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Soc}"         Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind PackVoltage}" Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Current}"     Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind Status}"      Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="5" Text="{x:Bind MinCell}"     Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="6" Text="{x:Bind MaxCell}"     Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="7" Text="{x:Bind Delta}"       Style="{StaticResource StreamCellStyle}"/>
                                    <TextBlock Grid.Column="8" Text="{x:Bind Balancing}"   Style="{StaticResource StreamCellStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Placeholder saat belum ada data -->
                    <TextBlock x:Name="StreamEmptyText"
                               Text="Belum ada data — hubungkan ESP32 untuk melihat data stream."
                               FontSize="11" Opacity="0.45"
                               Margin="14,10,14,10"
                               Visibility="Collapsed"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
