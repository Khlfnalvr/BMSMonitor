<Page
    x:Class="BMSMonitor.Views.LoggingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BMSMonitor.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20,16,20,24" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top: status+controls | file settings -->
                <RowDefinition Height="Auto"/>   <!-- Live data section header -->
                <RowDefinition Height="Auto"/>   <!-- Live data card -->
            </Grid.RowDefinitions>

            <!-- ══ TOP ROW: left = file settings, right = status + controls ══ -->
            <!--
                Headers in Row 0, cards in Row 1 with Height="*". Both cards
                share Row 1's height (= max of their natural heights), so they
                always render at exactly the same height regardless of content.
            -->
            <Grid Grid.Row="0" ColumnSpacing="12" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Section headers -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{x:Bind Lang.Log_SecFileSettings, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{x:Bind Lang.Log_SecStatus, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>

                <!-- ── FILE SETTINGS (left) ───────────────────────────────── -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">

                            <!-- Folder row -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Lang.Log_Folder, Mode=OneWay}"
                                           FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                                <TextBlock x:Name="FolderText" Grid.Column="1"
                                           FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <Button x:Name="BrowseBtn"
                                        Grid.Column="2" Content="{x:Bind Lang.Log_Browse, Mode=OneWay}"
                                        Click="BrowseFolder_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Format row -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Lang.Log_Format, Mode=OneWay}"
                                           FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                                <ComboBox x:Name="FormatBox"
                                          Grid.Column="1"
                                          HorizontalAlignment="Left" MinWidth="200"
                                          SelectionChanged="FormatBox_SelectionChanged">
                                    <ComboBoxItem Content="CSV — comma-separated (.csv)"    IsSelected="True"/>
                                    <ComboBoxItem Content="TSV — tab-separated (.tsv)"/>
                                    <ComboBoxItem Content="Excel — workbook (.xlsx)"/>
                                    <ComboBoxItem Content="JSON — array of objects (.json)"/>
                                </ComboBox>
                            </Grid>

                            <!-- Filename row -->
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Lang.Log_Filename, Mode=OneWay}"
                                           FontSize="13" VerticalAlignment="Center" Opacity="0.65"/>
                                <TextBox x:Name="FileNameBox"
                                         Grid.Column="1"
                                         PlaceholderText="{x:Bind Lang.Log_PhAutoFilename, Mode=OneWay}"
                                         FontSize="12"/>
                            </Grid>

                        <!-- Full path preview -->
                        <TextBlock x:Name="FullPathText"
                                   FontSize="11" Opacity="0.45"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ── STATUS + CONTROLS (right, single card) ─────────────── -->
                <!--
                    Inner Grid (rather than StackPanel) so the buttons can be
                    pinned to the bottom via Grid.Row="*", keeping their
                    vertical position stable when the card stretches to match
                    File Settings height.
                -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- metrics -->
                            <RowDefinition Height="Auto"/>   <!-- divider -->
                            <RowDefinition Height="*"/>      <!-- hint (absorbs slack) -->
                            <RowDefinition Height="Auto"/>   <!-- buttons -->
                        </Grid.RowDefinitions>

                        <!-- Status metrics: State | Samples | Duration -->
                        <Grid Grid.Row="0" ColumnSpacing="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind Lang.Log_State, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="StateText" Text=""
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="1" Width="1"
                                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Margin="0,4"/>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind Lang.Log_Samples, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="SampleText" Text="0"
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Border Grid.Column="3" Width="1"
                                    Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                    Margin="0,4"/>

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind Lang.Log_Duration, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="DurationText" Text="—"
                                           Style="{StaticResource MetricValueStyle}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Divider between metrics and action controls -->
                        <Border Grid.Row="1" Height="1"
                                Background="{ThemeResource CardStrokeColorDefaultBrush}"/>

                        <!-- Hint (top-anchored in the star-sized slack row) -->
                        <TextBlock Grid.Row="2" x:Name="HintText"
                                   Text=""
                                   FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   VerticalAlignment="Top"/>

                        <!-- Action buttons — centered horizontally -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10"
                                    HorizontalAlignment="Center">
                            <Button x:Name="StartStopBtn"
                                    Content=""
                                    Style="{ThemeResource AccentButtonStyle}"
                                    MinWidth="140"
                                    Click="StartStopBtn_Click"/>
                            <Button Content="{x:Bind Lang.Log_OpenFolder, Mode=OneWay}"
                                    MinWidth="120"
                                    Click="OpenFolderBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ══ LIVE DATA STREAM — full width ══════════════════════════════ -->
            <TextBlock Grid.Row="1" Text="{x:Bind Lang.Log_SecLiveData, Mode=OneWay}"
                       Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,0"/>
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid x:Name="StreamContainer" MinHeight="40" Padding="14,0">
                        <TextBlock x:Name="StreamEmptyText"
                                   Text="{x:Bind Lang.Log_NoData, Mode=OneWay}"
                                   FontSize="11" Opacity="0.45"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </ScrollViewer>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
