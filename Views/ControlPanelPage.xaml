<Page
    x:Class="BMSMonitor.Views.ControlPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMSMonitor.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Page-local form layouts so we don't repeat ColumnDefinitions per row -->
        <Thickness x:Key="CardSpacing">0,8,0,0</Thickness>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="32,20,32,40">
            <!-- Centered, max-880px column. Stretches down to ~640px before scroll. -->
            <StackPanel Spacing="10" MaxWidth="880"
                        HorizontalAlignment="Center">

                <!-- ── SERIAL CONNECTION ──────────────────────────────────── -->
                <TextBlock Text="SERIAL CONNECTION" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="COM Port"
                                       Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox Grid.Column="1" x:Name="ComboCOM"
                                      PlaceholderText="Scanning ports…"
                                      HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="Refresh" Click="RefreshPorts_Click"/>
                            <Button Grid.Column="3" x:Name="ConnectBtn"
                                    Content="Connect" Style="{ThemeResource AccentButtonStyle}"
                                    Click="ConnectBtn_Click"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Baud Rate" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox Grid.Column="1" x:Name="ComboBaud" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="9600"/>
                                <ComboBoxItem Content="19200"/>
                                <ComboBoxItem Content="38400"/>
                                <ComboBoxItem Content="57600"/>
                                <ComboBoxItem Content="115200" IsSelected="True"/>
                                <ComboBoxItem Content="230400"/>
                                <ComboBoxItem Content="460800"/>
                                <ComboBoxItem Content="921600"/>
                            </ComboBox>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Status" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="ConnStatusText"
                                       VerticalAlignment="Center" FontSize="13"
                                       Text="Not connected"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── BATTERY CAPACITY ─────────────────────────────────── -->
                <TextBlock Text="BATTERY CAPACITY" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nominal Capacity"
                                   Style="{StaticResource FormLabelStyle}"/>
                        <NumberBox Grid.Column="1" x:Name="NbxCapacity"
                                   Value="20" Minimum="1" Maximum="500"
                                   SmallChange="1" LargeChange="5"
                                   SpinButtonPlacementMode="Compact"
                                   HorizontalAlignment="Stretch"/>
                        <TextBlock Grid.Column="2" Text="Ah" VerticalAlignment="Center"
                                   Opacity="0.65" FontSize="13"/>
                        <TextBlock Grid.Column="3" Text="Used to calculate remaining capacity (mAh) on dashboard."
                                   FontSize="11" Opacity="0.5" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <!-- ── PROTECTION THRESHOLDS ─────────────────────────────── -->
                <TextBlock Text="PROTECTION THRESHOLDS" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Overvoltage Cutoff"  Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxOvervolt"
                                       Value="4.20" Minimum="3.5" Maximum="4.35"
                                       SmallChange="0.01" LargeChange="0.1"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="V" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Undervoltage Cutoff" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxUndervolt"
                                       Value="2.80" Minimum="2.0" Maximum="3.5"
                                       SmallChange="0.01" LargeChange="0.1"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="V" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Low Voltage Warning"  Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxLowVolt"
                                       Value="3.00" Minimum="2.5" Maximum="3.8"
                                       SmallChange="0.01" LargeChange="0.1"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="V" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Over-Temp Warning"   Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxTempWarn"
                                       Value="60" Minimum="30" Maximum="90"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="°C" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Over-Temp Cutoff"    Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxTempCutoff"
                                       Value="70" Minimum="40" Maximum="100"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="°C" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── CURRENT LIMITS ────────────────────────────────────── -->
                <TextBlock Text="CURRENT LIMITS" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max Charge Current"     Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxMaxCharge"
                                       Value="20" Minimum="1" Maximum="60"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="A" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max Discharge Current"  Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxMaxDischarge"
                                       Value="40" Minimum="1" Maximum="120"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="A" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Max DoD"                Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxMaxDod"
                                       Value="80" Minimum="50" Maximum="100"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── BALANCING SETTINGS ────────────────────────────────── -->
                <TextBlock Text="ACTIVE BALANCING (LTC8584)" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start Delta"  Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxBalStart"
                                       Value="20" Minimum="5" Maximum="100"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="mV" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stop Delta"   Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox  Grid.Column="1" x:Name="NbxBalStop"
                                       Value="5" Minimum="1" Maximum="50"
                                       SmallChange="1" LargeChange="5"
                                       SpinButtonPlacementMode="Compact"
                                       HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="mV" VerticalAlignment="Center"
                                       Opacity="0.65" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── ACTION BUTTONS ─────────────────────────────────────── -->
                <StackPanel Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">
                    <Button Content="Reset to Defaults" Click="ResetDefaults_Click"
                            MinWidth="140"/>
                    <Button Content="Apply Settings"
                            Style="{ThemeResource AccentButtonStyle}"
                            Click="ApplySettings_Click"
                            MinWidth="140"/>
                </StackPanel>

                <!-- Feedback bar -->
                <InfoBar x:Name="FeedbackBar" IsOpen="False" IsClosable="True"
                         Margin="0,4,0,0"/>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
