<Page
    x:Class="BMSMonitor.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:BMSMonitor.ViewModels"
    xmlns:conv="using:BMSMonitor.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:StatusToForegroundConverter  x:Key="StatusToFgConverter"/>
        <conv:TempToForegroundConverter    x:Key="TempToFgConverter"/>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVisConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,16,20,24" Spacing="8">

            <!-- ── PACK OVERVIEW ─────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Dash_SecPackOverview, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Pack Voltage -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_PackVoltage, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.PackVoltageText, Mode=OneWay}"
                                   Style="{StaticResource CardValueStyle}"/>
                        <TextBlock Text="{x:Bind Lang.Dash_PackNominal, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                    </StackPanel>
                </Border>

                <!-- SOC -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_StateOfCharge, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.SocText, Mode=OneWay}"
                                   Style="{StaticResource CardValueStyle}"/>
                        <ProgressBar Value="{x:Bind ViewModel.Soc, Mode=OneWay}"
                                     Maximum="100" Height="4" CornerRadius="2"/>
                    </StackPanel>
                </Border>

                <!-- Remaining Capacity -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="2">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_Remaining, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.RemainingCapacityText, Mode=OneWay}"
                                   Style="{StaticResource CardValueStyle}"/>
                        <TextBlock Text="{x:Bind Lang.Dash_RemainingSub, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                    </StackPanel>
                </Border>

                <!-- Current -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="3">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_Current, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.CurrentText, Mode=OneWay}"
                                   Style="{StaticResource CardValueStyle}"/>
                        <TextBlock Text="{x:Bind Lang.Dash_CurrentSub, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <Border Style="{StaticResource CardStyle}" Grid.Column="4">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Com_Status, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                        <TextBlock Text="{x:Bind ViewModel.PackStatus, Mode=OneWay}"
                                   Style="{StaticResource CardValueStyle}"
                                   Foreground="{x:Bind ViewModel.PackStatus, Converter={StaticResource StatusToFgConverter}, Mode=OneWay}"/>
                        <TextBlock Text="{x:Bind Lang.Dash_PackConfig, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── SOC HISTORY CHART ─────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind Lang.Dash_SecSocHistory, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="SaveSocBtn"
                        Width="36" Height="28" Padding="0"
                        Click="SaveSocChart_Click"
                        ToolTipService.ToolTip="{x:Bind Lang.Dash_SaveChart, Mode=OneWay}">
                    <SymbolIcon Symbol="Save"/>
                </Button>
            </Grid>
            <Border x:Name="SocChartCard" Style="{StaticResource CardStyle}">
                <Grid x:Name="SocChartArea" RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Y-axis labels -->
                        <Grid x:Name="SocYAxisGrid" Grid.Column="0" Height="130">
                            <TextBlock Text="100" FontSize="9" Opacity="0.45"
                                       VerticalAlignment="Top" HorizontalAlignment="Right"/>
                            <TextBlock Text="50" FontSize="9" Opacity="0.45"
                                       VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            <TextBlock Text="0" FontSize="9" Opacity="0.45"
                                       VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Chart canvas -->
                        <Canvas x:Name="SocChartCanvas" Grid.Column="1" Height="130"
                                SizeChanged="SocChartCanvas_SizeChanged">
                            <Line x:Name="GridLine75" StrokeThickness="1" StrokeDashArray="4,3"/>
                            <Line x:Name="GridLine50" StrokeThickness="1" StrokeDashArray="4,3"/>
                            <Line x:Name="GridLine25" StrokeThickness="1" StrokeDashArray="4,3"/>
                            <Polygon  x:Name="SocFill"   Opacity="0.15"/>
                            <Polyline x:Name="SocLine"   StrokeThickness="2"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            <!-- X-axis ticks are pre-allocated programmatically (DashboardPage.xaml.cs) -->
                            <!-- Tick text is dynamic: count, interval and unit auto-scale with the timeframe. -->

                        </Canvas>
                    </Grid>

                    <!-- X-axis legend: window duration -->
                    <Grid Grid.Row="1" Margin="36,0,0,0">
                        <TextBlock x:Name="SocTimeAgoLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="SocNowLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── V/I HISTORY CHART ─────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{x:Bind Lang.Dash_SecViHistory, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
                <Button Grid.Column="1" x:Name="SaveViBtn"
                        Width="36" Height="28" Padding="0"
                        Click="SaveVIChart_Click"
                        ToolTipService.ToolTip="{x:Bind Lang.Dash_SaveChart, Mode=OneWay}">
                    <SymbolIcon Symbol="Save"/>
                </Button>
            </Grid>
            <Border x:Name="VIChartCard" Style="{StaticResource CardStyle}">
                <Grid x:Name="VIChartArea" RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 3-column layout: V-axis | canvas | I-axis -->
                    <Grid Grid.Row="0" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <!-- Voltage Y-axis labels (left, right-aligned) -->
                        <Canvas x:Name="VAxisCanvas" Grid.Column="0" Height="180">
                            <TextBlock x:Name="VLabel4" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="0"/>
                            <TextBlock x:Name="VLabel3" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="39"/>
                            <TextBlock x:Name="VLabel2" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="84"/>
                            <TextBlock x:Name="VLabel1" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="129"/>
                            <TextBlock x:Name="VLabel0" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="168"/>
                        </Canvas>

                        <!-- Chart canvas -->
                        <Canvas x:Name="VIChartCanvas" Grid.Column="1" Height="180"
                                SizeChanged="VIChartCanvas_SizeChanged">
                            <Line x:Name="VIGridH1" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Line x:Name="VIGridH2" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Line x:Name="VIGridH3" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Polyline x:Name="VoltageLine" StrokeThickness="2"
                                      StrokeLineJoin="Round" Fill="Transparent"/>
                            <Polyline x:Name="CurrentLine" StrokeThickness="2"
                                      StrokeLineJoin="Round" Fill="Transparent"
                                      StrokeDashArray="5,2"/>
                            <!-- X-axis ticks are pre-allocated programmatically (DashboardPage.xaml.cs) -->

                        </Canvas>

                        <!-- Current Y-axis labels (right, left-aligned) -->
                        <Canvas x:Name="IAxisCanvas" Grid.Column="2" Height="180">
                            <TextBlock x:Name="ILabel4" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="0"/>
                            <TextBlock x:Name="ILabel3" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="39"/>
                            <TextBlock x:Name="ILabel2" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="84"/>
                            <TextBlock x:Name="ILabel1" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="129"/>
                            <TextBlock x:Name="ILabel0" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="168"/>
                        </Canvas>
                    </Grid>

                    <!-- Legend -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16"
                                HorizontalAlignment="Center" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Rectangle x:Name="VLegendRect" Width="18" Height="3" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Lang.Dash_VoltageV, Mode=OneWay}" FontSize="10" Opacity="0.65" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Rectangle x:Name="ILegendRect" Width="18" Height="3" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Lang.Dash_CurrentA, Mode=OneWay}" FontSize="10" Opacity="0.65" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- X-axis labels: window duration -->
                    <Grid Grid.Row="2" Margin="44,0,44,0">
                        <TextBlock x:Name="VITimeAgoLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="VINowLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── TIME RANGE TRIM ──────────────────────────────────── -->
            <TextBlock Text="Time Range (trim)" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TrimRangeText"
                                   Text="No data captured yet"
                                   FontFamily="Consolas" FontSize="12" Opacity="0.75"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="ResetTrimBtn"
                                Content="Reset"
                                Click="ResetTrim_Click"
                                FontSize="11" Padding="10,4"
                                IsEnabled="False"/>
                    </Grid>

                    <!-- Trim bar canvas -->
                    <Canvas x:Name="TrimCanvas" Height="34"
                            HorizontalAlignment="Stretch"
                            Background="Transparent"
                            SizeChanged="TrimCanvas_SizeChanged">
                        <!-- Background track (full data range) -->
                        <Border x:Name="TrimTrack"
                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                Height="8" CornerRadius="4"
                                Canvas.Top="13"/>
                        <!-- Selected segment (between handles) -->
                        <Border x:Name="TrimSelection"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                Opacity="0.45"
                                Height="8" CornerRadius="4"
                                Canvas.Top="13"/>
                        <!-- Start handle -->
                        <Border x:Name="StartThumb"
                                Width="14" Height="30"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource AccentFillColorTertiaryBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Canvas.Top="2"
                                ManipulationMode="TranslateX"
                                PointerPressed="StartThumb_PointerPressed"
                                PointerMoved="Thumb_PointerMoved"
                                PointerReleased="Thumb_PointerReleased"
                                PointerCaptureLost="Thumb_PointerReleased"/>
                        <!-- End handle -->
                        <Border x:Name="EndThumb"
                                Width="14" Height="30"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource AccentFillColorTertiaryBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Canvas.Top="2"
                                ManipulationMode="TranslateX"
                                PointerPressed="EndThumb_PointerPressed"
                                PointerMoved="Thumb_PointerMoved"
                                PointerReleased="Thumb_PointerReleased"
                                PointerCaptureLost="Thumb_PointerReleased"/>
                    </Canvas>

                    <!-- Time labels (full range extents) -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DataStartLabel" Text="—"
                                   FontFamily="Consolas" FontSize="10" Opacity="0.55"/>
                        <TextBlock Grid.Column="1" x:Name="DataEndLabel" Text="—"
                                   FontFamily="Consolas" FontSize="10" Opacity="0.55"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <TextBlock FontSize="10" Opacity="0.45" TextWrapping="Wrap"
                               Text="Drag the handles to select a time range. The charts update live to the selected window. Reset to return to the rolling view."/>
                </StackPanel>
            </Border>

            <!-- ── TEMPERATURE HISTORY CHART ─────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind Lang.Dash_SecTempHistory, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="SaveTempBtn"
                        Width="36" Height="28" Padding="0"
                        Click="SaveTempChart_Click"
                        ToolTipService.ToolTip="{x:Bind Lang.Dash_SaveChart, Mode=OneWay}">
                    <SymbolIcon Symbol="Save"/>
                </Button>
            </Grid>
            <Border x:Name="TempChartCard" Style="{StaticResource CardStyle}">
                <Grid x:Name="TempChartArea" RowSpacing="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 3-column layout: C-axis | canvas | F-axis -->
                    <Grid Grid.Row="0" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>

                        <!-- Celsius Y-axis labels (left, right-aligned) -->
                        <Canvas x:Name="CAxisCanvas" Grid.Column="0" Height="160">
                            <TextBlock Text="°C" FontSize="9" FontWeight="SemiBold" Opacity="0.7"
                                       Width="36" TextAlignment="Right" Canvas.Top="0"/>
                            <TextBlock x:Name="CLabel4" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="14"/>
                            <TextBlock x:Name="CLabel3" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="46"/>
                            <TextBlock x:Name="CLabel2" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="86"/>
                            <TextBlock x:Name="CLabel1" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="126"/>
                            <TextBlock x:Name="CLabel0" Text="—" FontSize="9" Opacity="0.55"
                                       Width="36" TextAlignment="Right" Canvas.Top="148"/>
                        </Canvas>

                        <!-- Chart canvas -->
                        <Canvas x:Name="TempChartCanvas" Grid.Column="1" Height="160"
                                SizeChanged="TempChartCanvas_SizeChanged">
                            <Line x:Name="TempGridH1" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Line x:Name="TempGridH2" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <Line x:Name="TempGridH3" StrokeThickness="1" StrokeDashArray="3,3"/>
                            <!-- 10 sensor polylines (pre-created in code-behind) -->
                        </Canvas>

                        <!-- Fahrenheit Y-axis labels (right, left-aligned) -->
                        <Canvas x:Name="FAxisCanvas" Grid.Column="2" Height="160">
                            <TextBlock Text="°F" FontSize="9" FontWeight="SemiBold" Opacity="0.7"
                                       Canvas.Left="2" Canvas.Top="0"/>
                            <TextBlock x:Name="FLabel4" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="14"/>
                            <TextBlock x:Name="FLabel3" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="46"/>
                            <TextBlock x:Name="FLabel2" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="86"/>
                            <TextBlock x:Name="FLabel1" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="126"/>
                            <TextBlock x:Name="FLabel0" Text="—" FontSize="9" Opacity="0.55"
                                       Canvas.Left="2" Canvas.Top="148"/>
                        </Canvas>
                    </Grid>

                    <!-- Legend (populated in code-behind) -->
                    <StackPanel Grid.Row="1" x:Name="TempLegendPanel"
                                Orientation="Horizontal" Spacing="12"
                                HorizontalAlignment="Center" Margin="0,4,0,0"/>

                    <!-- X-axis labels -->
                    <Grid Grid.Row="2" Margin="48,0,48,0">
                        <TextBlock x:Name="TempTimeAgoLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Left"/>
                        <TextBlock x:Name="TempNowLabel" FontSize="10" Opacity="0.4"
                                   HorizontalAlignment="Right" FontFamily="Consolas"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ── VOLTAGE SUMMARY ────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Dash_SecCellSummary, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Com_Min, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.MinCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Com_Max, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.MaxCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="3" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Com_Avg, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.AvgCellText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="5" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Com_Delta, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Bind ViewModel.DeltaText, Mode=OneWay}"
                                   Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── BALANCING STATUS ─────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Dash_BalancingStatus, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_ActiveCells, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{x:Bind ViewModel.BalancingText, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_CellDelta, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{x:Bind ViewModel.DeltaText, Mode=OneWay}"
                                   FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Dash_Method, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{x:Bind Lang.Dash_ActiveMethod, Mode=OneWay}" FontSize="14" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
