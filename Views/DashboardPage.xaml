<Page
    x:Class="BMSMonitor.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BMSMonitor.Models"
    xmlns:vm="using:BMSMonitor.ViewModels"
    xmlns:conv="using:BMSMonitor.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:StatusToForegroundConverter  x:Key="StatusToFgConverter"/>
        <conv:TempToForegroundConverter    x:Key="TempToFgConverter"/>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVisConverter"/>
    </Page.Resources>

    <!--
        Root is a ScrollViewer hosting a Grid (not a StackPanel) so the
        ChartsGrid in row 1 can take Height="*" and fill the remaining
        vertical space. MinHeight is bound in code-behind to the viewport
        height so the layout stays tall enough to fill the window but still
        scrolls when the window is shorter than the natural content.
    -->
    <ScrollViewer x:Name="DashboardScroller" VerticalScrollBarVisibility="Auto">
        <Grid x:Name="DashboardRoot" Padding="20,16,20,16" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--
                Flat 2-col / 6-row Grid. Each left section gets its own row; the
                alert card spans rows 1-5 on the right. Sharing rows makes the
                alert card's bottom edge align with the Balancing Status card's
                bottom edge by construction — no code-behind sync needed.
            -->
            <Grid x:Name="DashboardTopGrid" Grid.Row="0" ColumnSpacing="10" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── PACK OVERVIEW ─────────────────────────────────────── -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{x:Bind Lang.Dash_SecPackOverview, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <Grid x:Name="PackOverviewCards" Grid.Row="1" Grid.Column="0" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_PackVoltage, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.PackVoltageText, Mode=OneWay}"
                                       Style="{StaticResource CardValueStyle}"/>
                            <TextBlock Text="{x:Bind Lang.Dash_PackNominal, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="1">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_StateOfCharge, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.SocText, Mode=OneWay}"
                                       Style="{StaticResource CardValueStyle}"/>
                            <ProgressBar Value="{x:Bind ViewModel.Soc, Mode=OneWay}"
                                         Maximum="100" Height="4" CornerRadius="2"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="2">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_Remaining, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.RemainingCapacityText, Mode=OneWay}"
                                       Style="{StaticResource CardValueStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.TimeToEmptyText, Mode=OneWay}" FontSize="11" Opacity="0.55"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="3">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_Current, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.CurrentText, Mode=OneWay}"
                                       Style="{StaticResource CardValueStyle}"/>
                            <TextBlock Text="{x:Bind Lang.Dash_CurrentSub, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Column="4">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Com_Status, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"/>
                            <TextBlock Text="{x:Bind ViewModel.PackStatusText, Mode=OneWay}"
                                       Style="{StaticResource CardValueStyle}"
                                       Foreground="{x:Bind ViewModel.PackStatus, Converter={StaticResource StatusToFgConverter}, Mode=OneWay}"/>
                            <TextBlock Text="{x:Bind Lang.Dash_PackConfig, Mode=OneWay}" FontSize="11" Opacity="0.45"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── CELL VOLTAGE SUMMARY ───────────────────────────────── -->
                <TextBlock x:Name="CellSummaryHeader"
                           Grid.Row="2" Grid.Column="0"
                           Text="{x:Bind Lang.Dash_SecCellSummary, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <Border x:Name="CellSummaryCard"
                        Grid.Row="3" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Com_Min, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.MinCellText, Mode=OneWay}"
                                       Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Com_Max, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.MaxCellText, Mode=OneWay}"
                                       Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="3" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                        <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Com_Avg, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.AvgCellText, Mode=OneWay}"
                                       Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="5" Width="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                        <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Com_Delta, Mode=OneWay}" Style="{StaticResource CardLabelStyle}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{x:Bind ViewModel.DeltaText, Mode=OneWay}"
                                       Style="{StaticResource MetricValueStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── BALANCING STATUS ───────────────────────────────────── -->
                <TextBlock x:Name="BalancingHeader"
                           Grid.Row="4" Grid.Column="0"
                           Text="{x:Bind Lang.Dash_BalancingStatus, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <Border x:Name="BalancingCard"
                        Grid.Row="5" Grid.Column="0" Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_ActiveCells, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                            <TextBlock Text="{x:Bind ViewModel.BalancingText, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_CellDelta, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                            <TextBlock Text="{x:Bind ViewModel.DeltaText, Mode=OneWay}"
                                       FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="{x:Bind Lang.Dash_Method, Mode=OneWay}" FontSize="12" Opacity="0.6"/>
                            <TextBlock Text="{x:Bind Lang.Dash_ActiveMethod, Mode=OneWay}" FontSize="14" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── ALERT & WARNING ────────────────────────────────────── -->
                <TextBlock x:Name="AlertSectionHeader"
                           Grid.Row="0" Grid.Column="1"
                           Text="{x:Bind Lang.Dash_SecAlertsWarnings, Mode=OneWay}"
                           Style="{StaticResource SectionHeaderStyle}"/>
                <Border x:Name="AlertCardBorder"
                        Grid.Row="1" Grid.RowSpan="5" Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Padding="0"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <ListView x:Name="DashboardAlertListView"
                                  ItemsSource="{x:Bind DashboardAlerts}"
                                  SelectionMode="None"
                                  Padding="10"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:AlertRecord">
                                    <Grid ColumnSpacing="8" Padding="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0"
                                                  FontFamily="Segoe MDL2 Assets"
                                                  Glyph="{x:Bind SeverityIcon}"
                                                  FontSize="14"
                                                  Foreground="{x:Bind SeverityColorBrush}"
                                                  Margin="0,2,0,0"
                                                  VerticalAlignment="Top"/>

                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{x:Bind Title}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Body}"
                                                       FontSize="11"
                                                       Opacity="0.68"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxLines="3"/>
                                            <TextBlock Text="{x:Bind TimeText}"
                                                       FontSize="10"
                                                       Opacity="0.48"
                                                       FontFamily="Consolas"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel x:Name="DashboardNoAlertsState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                      Glyph="&#xE930;"
                                      FontSize="28"
                                      Opacity="0.4"/>
                            <TextBlock Text="{x:Bind Lang.Ui_NoAlerts, Mode=OneWay}"
                                       FontSize="12"
                                       Opacity="0.56"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="ChartsGrid" Grid.Row="1" ColumnSpacing="10" RowSpacing="8"
                  VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="ChartsRow0" Height="*"/>
                    <RowDefinition x:Name="ChartsRow1" Height="*"/>
                </Grid.RowDefinitions>

                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="ChartsStacked">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0"/>
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SocChartContainer.(Grid.ColumnSpan)" Value="2"/>
                                <Setter Target="ViChartContainer.(Grid.Row)" Value="1"/>
                                <Setter Target="ViChartContainer.(Grid.Column)" Value="0"/>
                                <Setter Target="ViChartContainer.(Grid.ColumnSpan)" Value="2"/>
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="ChartsSideBySide">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1100"/>
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="SocChartContainer.(Grid.ColumnSpan)" Value="1"/>
                                <Setter Target="ViChartContainer.(Grid.Row)" Value="0"/>
                                <Setter Target="ViChartContainer.(Grid.Column)" Value="1"/>
                                <Setter Target="ViChartContainer.(Grid.ColumnSpan)" Value="1"/>
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <!-- ── SOC HISTORY CHART ─────────────────────────────────── -->
                <!--
                    StackPanel → Grid so the Border (chart card) can take row
                    Height="*" and stretch to fill the available vertical
                    space inside ChartsGrid's star row.
                -->
                <Grid x:Name="SocChartContainer" Grid.Row="0" Grid.Column="0" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Lang.Dash_SecSocHistory, Mode=OneWay}"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="SaveSocBtn"
                                Height="22" Padding="5,2" MinWidth="0"
                                Click="SaveSocChart_Click"
                                ToolTipService.ToolTip="{x:Bind Lang.Dash_SaveChart, Mode=OneWay}">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Border x:Name="SocChartCard" Grid.Row="1"
                            Style="{StaticResource CardStyle}"
                            VerticalAlignment="Stretch">
                        <Grid x:Name="SocChartArea" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Y-axis labels -->
                                <Grid x:Name="SocYAxisGrid" Grid.Column="0">
                                    <TextBlock Text="100" FontSize="9" Opacity="0.45"
                                               VerticalAlignment="Top" HorizontalAlignment="Right"/>
                                    <TextBlock Text="50" FontSize="9" Opacity="0.45"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    <TextBlock Text="0" FontSize="9" Opacity="0.45"
                                               VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                                </Grid>

                                <!-- Chart canvas — Height comes from the star row so it grows with the page -->
                                <Canvas x:Name="SocChartCanvas" Grid.Column="1" MinHeight="160"
                                        SizeChanged="SocChartCanvas_SizeChanged">
                                    <Line x:Name="GridLine75" StrokeThickness="1" StrokeDashArray="4,3"/>
                                    <Line x:Name="GridLine50" StrokeThickness="1" StrokeDashArray="4,3"/>
                                    <Line x:Name="GridLine25" StrokeThickness="1" StrokeDashArray="4,3"/>
                                    <Polygon  x:Name="SocFill"   Opacity="0.15"/>
                                    <Polyline x:Name="SocLine"   StrokeThickness="2"
                                              StrokeLineJoin="Round" Fill="Transparent"/>
                                    <!-- X-axis ticks are pre-allocated programmatically (DashboardPage.xaml.cs) -->
                                </Canvas>
                            </Grid>

                            <!--
                                Legend row — mirrors the V/I chart's legend row so both
                                cards have the same overall height when sat side-by-side.
                            -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16"
                                        HorizontalAlignment="Center" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Rectangle x:Name="SocLegendRect" Width="18" Height="3" VerticalAlignment="Center"/>
                                    <TextBlock Text="SOC (%)" FontSize="10" Opacity="0.65" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- X-axis legend: window duration -->
                            <Grid Grid.Row="2" Margin="36,0,0,0">
                                <TextBlock x:Name="SocTimeAgoLabel" FontSize="10" Opacity="0.4"
                                           HorizontalAlignment="Left"/>
                                <TextBlock x:Name="SocNowLabel" FontSize="10" Opacity="0.4"
                                           HorizontalAlignment="Right" FontFamily="Consolas"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── V/I HISTORY CHART ─────────────────────────────────── -->
                <Grid x:Name="ViChartContainer" Grid.Row="0" Grid.Column="1" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Lang.Dash_SecViHistory, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
                        <Button Grid.Column="1" x:Name="SaveViBtn"
                                Height="22" Padding="5,2" MinWidth="0"
                                Click="SaveVIChart_Click"
                                ToolTipService.ToolTip="{x:Bind Lang.Dash_SaveChart, Mode=OneWay}">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74E;" FontSize="12"/>
                        </Button>
                    </Grid>
                    <Border x:Name="VIChartCard" Grid.Row="1"
                            Style="{StaticResource CardStyle}"
                            VerticalAlignment="Stretch">
                        <Grid x:Name="VIChartArea" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 3-column layout: V-axis | canvas | I-axis -->
                            <Grid Grid.Row="0" ColumnSpacing="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <!-- Voltage Y-axis labels (left, right-aligned) -->
                                <!-- Heights drop to MinHeight so the axes track the chart canvas as it grows. -->
                                <Canvas x:Name="VAxisCanvas" Grid.Column="0" MinHeight="160">
                                    <TextBlock x:Name="VLabel4" Text="—" FontSize="9" Opacity="0.55"
                                               Width="36" TextAlignment="Right" Canvas.Top="0"/>
                                    <TextBlock x:Name="VLabel3" Text="—" FontSize="9" Opacity="0.55"
                                               Width="36" TextAlignment="Right" Canvas.Top="35"/>
                                    <TextBlock x:Name="VLabel2" Text="—" FontSize="9" Opacity="0.55"
                                               Width="36" TextAlignment="Right" Canvas.Top="74"/>
                                    <TextBlock x:Name="VLabel1" Text="—" FontSize="9" Opacity="0.55"
                                               Width="36" TextAlignment="Right" Canvas.Top="114"/>
                                    <TextBlock x:Name="VLabel0" Text="—" FontSize="9" Opacity="0.55"
                                               Width="36" TextAlignment="Right" Canvas.Top="149"/>
                                </Canvas>

                                <!-- Chart canvas — Height comes from the star row -->
                                <Canvas x:Name="VIChartCanvas" Grid.Column="1" MinHeight="160"
                                        SizeChanged="VIChartCanvas_SizeChanged">
                                    <Line x:Name="VIGridH1" StrokeThickness="1" StrokeDashArray="3,3"/>
                                    <Line x:Name="VIGridH2" StrokeThickness="1" StrokeDashArray="3,3"/>
                                    <Line x:Name="VIGridH3" StrokeThickness="1" StrokeDashArray="3,3"/>
                                    <Polyline x:Name="VoltageLine" StrokeThickness="2"
                                              StrokeLineJoin="Round" Fill="Transparent"/>
                                    <Polyline x:Name="CurrentLine" StrokeThickness="2"
                                              StrokeLineJoin="Round" Fill="Transparent"
                                              StrokeDashArray="5,2"/>
                                    <!-- X-axis ticks are pre-allocated programmatically (DashboardPage.xaml.cs) -->
                                </Canvas>

                                <!-- Current Y-axis labels (right, left-aligned) -->
                                <Canvas x:Name="IAxisCanvas" Grid.Column="2" MinHeight="160">
                                    <TextBlock x:Name="ILabel4" Text="—" FontSize="9" Opacity="0.55"
                                               Canvas.Left="2" Canvas.Top="0"/>
                                    <TextBlock x:Name="ILabel3" Text="—" FontSize="9" Opacity="0.55"
                                               Canvas.Left="2" Canvas.Top="35"/>
                                    <TextBlock x:Name="ILabel2" Text="—" FontSize="9" Opacity="0.55"
                                               Canvas.Left="2" Canvas.Top="74"/>
                                    <TextBlock x:Name="ILabel1" Text="—" FontSize="9" Opacity="0.55"
                                               Canvas.Left="2" Canvas.Top="114"/>
                                    <TextBlock x:Name="ILabel0" Text="—" FontSize="9" Opacity="0.55"
                                               Canvas.Left="2" Canvas.Top="149"/>
                                </Canvas>
                            </Grid>

                            <!-- Legend -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16"
                                        HorizontalAlignment="Center" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Rectangle x:Name="VLegendRect" Width="18" Height="3" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="VLegendText"
                                               Text="{x:Bind Lang.Dash_VoltageV, Mode=OneWay}"
                                               FontSize="10" Opacity="0.65" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Rectangle x:Name="ILegendRect" Width="18" Height="3" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Lang.Dash_CurrentA, Mode=OneWay}" FontSize="10" Opacity="0.65" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- X-axis labels: window duration -->
                            <Grid Grid.Row="2" Margin="44,0,44,0">
                                <TextBlock x:Name="VITimeAgoLabel" FontSize="10" Opacity="0.4"
                                           HorizontalAlignment="Left"/>
                                <TextBlock x:Name="VINowLabel" FontSize="10" Opacity="0.4"
                                           HorizontalAlignment="Right" FontFamily="Consolas"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

        </Grid>
    </ScrollViewer>
</Page>
