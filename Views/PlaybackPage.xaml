<Page
    x:Class="BMSMonitor.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,16,20,24" Spacing="8" MaxWidth="760"
                    HorizontalAlignment="Center">

            <!-- ── LOAD FILE ─────────────────────────────────────────────── -->
            <TextBlock Text="LOAD FILE" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FilePathText"
                                   Grid.Column="0"
                                   Text="No file loaded"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Browse…" Click="BrowseFile_Click"/>
                            <Button x:Name="UnloadBtn" Content="Unload"
                                    IsEnabled="False" Click="Unload_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="LoadStatusText"
                               FontSize="11" Opacity="0.55"
                               TextWrapping="Wrap"
                               Text="Browse and open a BMS Monitor CSV log file (.csv)."/>
                </StackPanel>
            </Border>

            <!-- ── FILE INFO ──────────────────────────────────────────────── -->
            <TextBlock Text="FILE INFO" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="FRAMES" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalFramesText" Text="—"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="ESTIMATED DURATION" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DurationText" Text="—"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="3" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="PLAYBACK SPEED" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <ComboBox x:Name="SpeedBox"
                                  HorizontalAlignment="Center"
                                  SelectedIndex="0"
                                  SelectionChanged="SpeedBox_SelectionChanged">
                            <ComboBoxItem Content="1×"/>
                            <ComboBoxItem Content="2×"/>
                            <ComboBoxItem Content="5×"/>
                            <ComboBoxItem Content="10×"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── HOW TO USE ─────────────────────────────────────────────── -->
            <TextBlock Text="HOW TO USE" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="HintText"
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Text="Browse and load a CSV file above, then use the playback bar that appears at the bottom of the window."/>
                    <TextBlock FontSize="11" Opacity="0.45" TextWrapping="Wrap"
                               Text="While playing, all pages (Dashboard, Cell View, etc.) update in real-time with the recorded data. Logging is paused automatically during playback. Click ✕ in the playback bar or press Unload to return to live mode."/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
