<Page
    x:Class="BMSMonitor.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20,16,20,24" Spacing="8" MaxWidth="760"
                    HorizontalAlignment="Center">

            <!-- ── LOAD FILE ─────────────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Pb_SecLoadFile, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FilePathText"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="{x:Bind Lang.Pb_Browse, Mode=OneWay}" Click="BrowseFile_Click"/>
                            <Button x:Name="UnloadBtn" Content="{x:Bind Lang.Pb_Unload, Mode=OneWay}"
                                    IsEnabled="False" Click="Unload_Click"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="LoadStatusText"
                               FontSize="11" Opacity="0.55"
                               TextWrapping="Wrap"
                               Text=""/>
                </StackPanel>
            </Border>

            <!-- ── FILE INFO ──────────────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Pb_SecFileInfo, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Pb_Frames, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalFramesText" Text="—"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Pb_EstDuration, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DurationText" Text="—"
                                   Style="{StaticResource MetricValueStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="3" Width="1"
                            Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="0,4"/>

                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="{x:Bind Lang.Pb_PlaybackSpeed, Mode=OneWay}" Style="{StaticResource CardLabelStyle}"
                                   HorizontalAlignment="Center"/>
                        <ComboBox x:Name="SpeedBox"
                                  HorizontalAlignment="Center"
                                  SelectedIndex="0"
                                  SelectionChanged="SpeedBox_SelectionChanged">
                            <ComboBoxItem Content="1×"/>
                            <ComboBoxItem Content="2×"/>
                            <ComboBoxItem Content="5×"/>
                            <ComboBoxItem Content="10×"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── HOW TO USE ─────────────────────────────────────────────── -->
            <TextBlock Text="{x:Bind Lang.Pb_SecHowToUse, Mode=OneWay}" Style="{StaticResource SectionHeaderStyle}"/>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="HintText"
                               FontSize="12" Opacity="0.65" TextWrapping="Wrap"
                               Text=""/>
                    <TextBlock FontSize="11" Opacity="0.45" TextWrapping="Wrap"
                               Text="{x:Bind Lang.Pb_HowToUse2, Mode=OneWay}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
