<Page
    x:Class="SOCTester.Views.ControlPanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,20,32,40">
            <StackPanel MaxWidth="900" HorizontalAlignment="Center" Spacing="8">

                <!-- ── SERIAL CONNECTION ─────────────────────────────────── -->
                <TextBlock Text="SERIAL CONNECTION" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="COM Port" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox  Grid.Column="1" x:Name="PortBox"
                                       HorizontalAlignment="Stretch"
                                       PlaceholderText="(none detected)"/>
                            <Button    Grid.Column="2" Content="Refresh"
                                       Click="RefreshBtn_Click"
                                       Margin="6,0,0,0"/>
                            <Button    Grid.Column="3" x:Name="ConnectBtn" Content="Connect"
                                       Style="{ThemeResource AccentButtonStyle}"
                                       Click="ConnectBtn_Click"
                                       Margin="6,0,0,0"
                                       MinWidth="100"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Baud Rate" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox  Grid.Column="1" x:Name="BaudBox"
                                       SelectedIndex="3" HorizontalAlignment="Stretch">
                                <ComboBoxItem>9600</ComboBoxItem>
                                <ComboBoxItem>19200</ComboBoxItem>
                                <ComboBoxItem>57600</ComboBoxItem>
                                <ComboBoxItem>115200</ComboBoxItem>
                                <ComboBoxItem>230400</ComboBoxItem>
                                <ComboBoxItem>460800</ComboBoxItem>
                            </ComboBox>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Status" Style="{StaticResource FormLabelStyle}"/>
                            <TextBlock Grid.Column="1" x:Name="StatusText"
                                       Text="Not connected" FontSize="13"
                                       VerticalAlignment="Center" Opacity="0.65"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── BATTERY CONFIG ─────────────────────────────────────── -->
                <TextBlock Text="BATTERY CONFIGURATION" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Nominal Capacity" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="CapacityBox"
                                       SmallChange="0.5" LargeChange="5"
                                       Minimum="0.1" Maximum="1000"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="Ah" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Cell Count (series)" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="CellCountBox"
                                       SmallChange="1" LargeChange="4"
                                       Minimum="1" Maximum="200"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="S" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pack Voltage @ 100% (full)" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="FullVoltageBox"
                                       SmallChange="0.1" LargeChange="1"
                                       Minimum="1" Maximum="1000"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="V" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pack Voltage @ 0% (empty)" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="EmptyVoltageBox"
                                       SmallChange="0.1" LargeChange="1"
                                       Minimum="0.1" Maximum="999"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="V" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Initial SOC (for coulomb)" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="InitialSocBox"
                                       SmallChange="1" LargeChange="10"
                                       Minimum="0" Maximum="100"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="%" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Current Zero Offset" Style="{StaticResource FormLabelStyle}"/>
                            <NumberBox Grid.Column="1" x:Name="OffsetBox"
                                       SmallChange="0.01" LargeChange="0.1"
                                       Minimum="-100" Maximum="100"
                                       SpinButtonPlacementMode="Compact"/>
                            <TextBlock Grid.Column="2" Text="A" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>

                    </StackPanel>
                </Border>

                <!-- ── SOC ALGORITHM ─────────────────────────────────────── -->
                <TextBlock Text="SOC ESTIMATION ALGORITHM" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="6">
                        <RadioButton x:Name="AlgDevice"   Content="Device-reported (use SOC from firmware)"
                                     GroupName="Alg"/>
                        <RadioButton x:Name="AlgVoltage"  Content="Voltage-based (linear V→SOC curve from full/empty thresholds)"
                                     GroupName="Alg"/>
                        <RadioButton x:Name="AlgCoulomb"  Content="Coulomb counting (integrate current × time)"
                                     GroupName="Alg"/>
                        <RadioButton x:Name="AlgHybrid"   Content="Hybrid (voltage anchor at rest, coulomb under load)"
                                     GroupName="Alg" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- ── ACTIONS ───────────────────────────────────────────── -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Button Content="Reset Coulomb Counter" Click="ResetCoulombBtn_Click"/>
                        <Button Content="Restore Defaults"      Click="DefaultsBtn_Click"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Apply Settings"
                            Style="{ThemeResource AccentButtonStyle}"
                            MinWidth="140"
                            Click="ApplyBtn_Click"/>
                </Grid>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
