<Window
    x:Class="BMSMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMSMonitor"
    xmlns:models="using:BMSMonitor.Models"
    Title="BMS Monitor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- playback bar -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.PaneHeader>
                <Image Source="logo.png"
                       Height="28"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Stretch="Uniform"/>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="{x:Bind Lang.Nav_Dashboard,    Mode=OneWay}" Tag="Dashboard"/>
                <NavigationViewItem Content="{x:Bind Lang.Nav_CellView,     Mode=OneWay}" Tag="CellView"/>
                <NavigationViewItem Content="{x:Bind Lang.Nav_ControlPanel, Mode=OneWay}" Tag="ControlPanel"/>
                <NavigationViewItem Content="{x:Bind Lang.Nav_Logging,      Mode=OneWay}" Tag="Logging"/>
                <NavigationViewItem Content="{x:Bind Lang.Nav_Playback,     Mode=OneWay}" Tag="Playback"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>

        <!--
            Invisible drag region — full width, IsHitTestVisible=False so NavView
            and the toggle below (in z-order) still receive pointer events.
        -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="32"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False"/>

        <!--
            Caption-style icon buttons — language picker + theme toggle, sitting
            immediately left of the minimize/maximize/close buttons (mirrors the
            Visual Studio Installer pattern). The code-behind shrinks
            AppTitleBar's right margin so this whole area sits outside the drag
            region.
        -->
        <Border x:Name="ThemeToggleArea"
                Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <!--
                    Alert history bell — badge count shows unread alerts.
                    Opens a flyout with the full alert log.
                -->
                <Button x:Name="AlertBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <Grid>
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="14"
                                  Glyph="&#xE7E7;"/>
                        <Border x:Name="AlertBadge"
                                Background="#FFDC3545"
                                CornerRadius="7"
                                Width="14" Height="14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,8,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="AlertBadgeText"
                                       Text="0"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="AlertFlyout"
                                Placement="Bottom"
                                Opening="AlertFlyout_Opening">
                            <StackPanel Width="340" Spacing="8">
                                <!-- Header -->
                                <Grid>
                                    <TextBlock Text="{x:Bind Lang.Ui_AlertHistory, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="ClearAlertsBtn"
                                            HorizontalAlignment="Right"
                                            Content="{x:Bind Lang.Ui_ClearAlerts, Mode=OneWay}"
                                            Click="ClearAlerts_Click"
                                            Padding="10,4"
                                            FontSize="11"/>
                                </Grid>

                                <!-- Alert list -->
                                <ListView x:Name="AlertListView"
                                          Height="320"
                                          SelectionMode="None"
                                          ItemsSource="{x:Bind AlertHistory}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:AlertRecord">
                                            <StackPanel Spacing="2" Padding="0,4,0,4">
                                                <TextBlock Text="{x:Bind Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"/>
                                                <TextBlock Text="{x:Bind Body}"
                                                           FontSize="11"
                                                           Opacity="0.7"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{x:Bind TimeText}"
                                                           FontSize="10"
                                                           Opacity="0.5"
                                                           FontFamily="Consolas"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Empty state -->
                                <TextBlock x:Name="NoAlertsText"
                                           Text="{x:Bind Lang.Ui_NoAlerts, Mode=OneWay}"
                                           FontSize="12"
                                           Opacity="0.5"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,8"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!--
                    CAN channel picker — sits to the left of the language /
                    theme buttons. Opens a flyout where the user can pick the
                    PCAN-USB channel + bitrate and connect without leaving
                    the current page. The small dot at the bottom-right
                    indicates live connection state.
                -->
                <Button x:Name="CanBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <Grid>
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="14"
                                  Glyph="&#xE839;"/>
                        <Ellipse x:Name="CanStatusDot"
                                 Width="6" Height="6"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,10,6"/>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="CanFlyout" Placement="Bottom">
                            <StackPanel Width="300" Spacing="10">
                                <TextBlock Text="{x:Bind Lang.Ui_CanConnection, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="14"/>

                                <!-- Channel row + refresh -->
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              x:Name="CapCanChannel"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="{x:Bind Lang.Ctrl_PhScanning, Mode=OneWay}"/>
                                    <Button Grid.Column="1"
                                            x:Name="CapRefreshBtn"
                                            Padding="8,6"
                                            ToolTipService.ToolTip="{x:Bind Lang.Ctrl_Refresh, Mode=OneWay}"
                                            Click="CapRefresh_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="12"/>
                                    </Button>
                                </Grid>

                                <!-- Bitrate row -->
                                <ComboBox x:Name="CapCanBitrate"
                                          HorizontalAlignment="Stretch"/>

                                <!-- Connect / Disconnect -->
                                <Button x:Name="CapConnectBtn"
                                        HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="CapConnectBtn_Click"
                                        Content="{x:Bind Lang.Ctrl_Connect, Mode=OneWay}"/>

                                <!-- Status -->
                                <TextBlock x:Name="CapConnStatus"
                                           FontSize="11" Opacity="0.7"
                                           TextWrapping="Wrap"
                                           Text="{x:Bind Lang.Ctrl_NotConnected, Mode=OneWay}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="LangBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE12B;"/>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <RadioMenuFlyoutItem x:Name="LangItemId" Text="Indonesia"  Tag="id" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemMs" Text="Malay"      Tag="ms" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemEn" Text="English"    Tag="en" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemNl" Text="Nederlands" Tag="nl" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemZh" Text="中文"        Tag="zh" GroupName="LangGroup" Click="LangItem_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="ThemeBtn"
                        Style="{StaticResource CaptionButtonStyle}"
                        Click="ThemeBtn_Click">
                    <FontIcon x:Name="ThemeIcon"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE706;"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ── Playback bar (Row 1, hidden when no file is loaded) ─────── -->
        <Border x:Name="PlaybackBar"
                Grid.Row="1"
                Padding="12,6,12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- transport buttons -->
                    <ColumnDefinition Width="*"/>       <!-- slider + labels -->
                    <ColumnDefinition Width="Auto"/>   <!-- close button -->
                </Grid.ColumnDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2"
                            VerticalAlignment="Center">
                    <Button x:Name="PbFirstBtn" Padding="8,6"
                            ToolTipService.ToolTip="First frame"
                            Click="PbFirst_Click">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PbPlayPauseBtn" Padding="10,6"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Play / Pause"
                            Click="PbPlayPause_Click">
                        <FontIcon x:Name="PbPlayPauseIcon"
                                  FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PbLastBtn" Padding="8,6"
                            ToolTipService.ToolTip="Last frame"
                            Click="PbLast_Click">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Scrub area: file name + frame counter + slider -->
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock x:Name="PbFileText"
                                   FontSize="10" FontWeight="SemiBold" Opacity="0.7"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PbFrameText"
                                   FontSize="10" Opacity="0.5" FontFamily="Consolas"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="PbSlider"
                            Minimum="0" Maximum="100" Value="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,-4,0,-6"
                            ValueChanged="PbSlider_ValueChanged"/>
                </StackPanel>

                <!-- Unload (close) button -->
                <Button Grid.Column="2" Padding="8,6"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Unload file and return to live mode"
                        Click="PbClose_Click">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Status bar (Row 2) ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                Padding="16,5"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DataSourceText, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Opacity="0.55" CharacterSpacing="80"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                           FontSize="12" Opacity="0.65"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="ClockText"
                           FontSize="12" Opacity="0.45"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
