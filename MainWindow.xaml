<Window
    x:Class="BMSMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMSMonitor"
    xmlns:models="using:BMSMonitor.Models"
    Title="BMS Monitor">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- playback bar -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded"
            RightTapped="TitleBar_RightTapped">

            <NavigationView.Resources>
                <!--
                    Compact top pane (32 px) matches the AppTitleBar height
                    exactly so the logo + nav labels sit visually centered
                    inside the title-bar strip.

                    The framework defaults position the selection underline a
                    few pixels above the item's bottom edge (via
                    NavigationViewItemBackgroundMargin +
                    TopNavigationViewItemSelectionIndicatorMargin), which is
                    what was causing the underline to overlap the text
                    descenders. We pin both to zero so the indicator sits
                    flush against the item bottom, freeing the full 30 px
                    above it for a vertically centered label.
                -->
                <x:Double x:Key="NavigationViewTopPaneHeight">32</x:Double>
                <x:Double x:Key="TopNavigationViewItemContentMinHeight">32</x:Double>
                <Thickness x:Key="NavigationViewItemButtonMargin">1,2</Thickness>
                <Thickness x:Key="TopNavigationViewItemContentOnlyContentPresenterMargin">6,0</Thickness>
                <Thickness x:Key="TopNavigationViewItemContentPresenterMargin">4,-1,6,-1</Thickness>
                <Thickness x:Key="NavigationViewItemBackgroundMargin">0,0,0,0</Thickness>
                <Thickness x:Key="TopNavigationViewItemSelectionIndicatorMargin">0,0,0,0</Thickness>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <Image Source="logo.png"
                       Height="22"
                       Margin="12,0,8,0"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Stretch="Uniform"/>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <!--
                    Content is wrapped in an explicit TextBlock with
                    VerticalAlignment=Center because the default item template
                    hard-codes ContentPresenter.VerticalAlignment to Stretch,
                    leaving the label glued to the indicator. The top-nav
                    template does not honor item padding for label placement,
                    so the labels are translated up slightly.
                -->
                <NavigationViewItem x:Name="NavDashboard"    Tag="Dashboard"    MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2">
                    <TextBlock Text="{x:Bind Lang.Nav_Dashboard,    Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavCellView"     Tag="CellView"     MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2">
                    <TextBlock Text="{x:Bind Lang.Nav_CellView,     Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavControlPanel" Tag="ControlPanel" MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2">
                    <TextBlock Text="{x:Bind Lang.Nav_ControlPanel, Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavLogging"      Tag="Logging"      MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2">
                    <TextBlock Text="{x:Bind Lang.Nav_Logging,      Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavPlayback"     Tag="Playback"     MinWidth="0" MinHeight="32" Height="32" Padding="0,0,0,2">
                    <TextBlock Text="{x:Bind Lang.Nav_Playback,     Mode=OneWay}" FontSize="12" VerticalAlignment="Center">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="-3"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>

        <!--
            Invisible drag region — full width, IsHitTestVisible=False so NavView
            and the toggle below (in z-order) still receive pointer events.
        -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="32"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False">
            <Border.ContextFlyout>
                <MenuFlyout x:Name="TitleBarCustomizeMenu" Placement="Bottom">
                    <MenuFlyoutSubItem x:Name="MenuView"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_View, Mode=OneWay}">
                        <ToggleMenuFlyoutItem x:Name="ViewNavDashboard"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_Dashboard, Mode=OneWay}"
                                              Tag="Dashboard"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavCellView"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_CellView, Mode=OneWay}"
                                              Tag="CellView"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavControlPanel"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_ControlPanel, Mode=OneWay}"
                                              Tag="ControlPanel"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavLogging"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_Logging, Mode=OneWay}"
                                              Tag="Logging"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                        <ToggleMenuFlyoutItem x:Name="ViewNavPlayback"
                                              FontSize="12"
                                              Text="{x:Bind Lang.Nav_Playback, Mode=OneWay}"
                                              Tag="Playback"
                                              IsChecked="True"
                                              Click="ViewNavToggle_Click"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem x:Name="MenuUnit"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_Unit, Mode=OneWay}">
                        <MenuFlyoutSubItem x:Name="MenuUnitTemperature"
                                           FontSize="12"
                                           Text="{x:Bind Lang.Ui_Menu_Temperature, Mode=OneWay}">
                            <RadioMenuFlyoutItem x:Name="UnitTempC"
                                                 FontSize="12"
                                                 Text="°C"
                                                 Tag="C"
                                                 GroupName="TemperatureUnitGroup"
                                                 Click="UnitTemperature_Click"/>
                            <RadioMenuFlyoutItem x:Name="UnitTempF"
                                                 FontSize="12"
                                                 Text="°F"
                                                 Tag="F"
                                                 GroupName="TemperatureUnitGroup"
                                                 Click="UnitTemperature_Click"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Name="MenuUnitVoltage"
                                           FontSize="12"
                                           Text="{x:Bind Lang.Ui_Menu_Voltage, Mode=OneWay}">
                            <RadioMenuFlyoutItem x:Name="UnitVoltageV"
                                                 FontSize="12"
                                                 Text="V"
                                                 Tag="V"
                                                 GroupName="VoltageUnitGroup"
                                                 Click="UnitVoltage_Click"/>
                            <RadioMenuFlyoutItem x:Name="UnitVoltageMv"
                                                 FontSize="12"
                                                 Text="mV"
                                                 Tag="mV"
                                                 GroupName="VoltageUnitGroup"
                                                 Click="UnitVoltage_Click"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSubItem x:Name="MenuUnitCapacity"
                                           FontSize="12"
                                           Text="{x:Bind Lang.Ui_Menu_Capacity, Mode=OneWay}">
                            <RadioMenuFlyoutItem x:Name="UnitCapacityMah"
                                                 FontSize="12"
                                                 Text="mAh"
                                                 Tag="mAh"
                                                 GroupName="CapacityUnitGroup"
                                                 Click="UnitCapacity_Click"/>
                            <RadioMenuFlyoutItem x:Name="UnitCapacityAh"
                                                 FontSize="12"
                                                 Text="Ah"
                                                 Tag="Ah"
                                                 GroupName="CapacityUnitGroup"
                                                 Click="UnitCapacity_Click"/>
                        </MenuFlyoutSubItem>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSubItem x:Name="MenuAbout"
                                       FontSize="12"
                                       Text="{x:Bind Lang.Ui_Menu_About, Mode=OneWay}">
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutProductText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutVersionText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutLicenseText, Mode=OneWay}"/>
                        <MenuFlyoutItem FontSize="12"
                                        IsHitTestVisible="False"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind AboutCopyrightText, Mode=OneWay}"/>
                    </MenuFlyoutSubItem>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuTour"
                                    FontSize="12"
                                    Text="{x:Bind Lang.Ui_Menu_Tour, Mode=OneWay}"
                                    Click="MenuTour_Click"/>
                    <MenuFlyoutSeparator/>
                    <MenuFlyoutItem x:Name="MenuRefreshApp"
                                    FontSize="12"
                                    Text="{x:Bind Lang.Ui_Menu_RefreshApp, Mode=OneWay}"
                                    Click="RefreshApp_Click"/>
                </MenuFlyout>
            </Border.ContextFlyout>
        </Border>

        <!--
            Caption-style icon buttons — language picker + theme toggle, sitting
            immediately left of the minimize/maximize/close buttons (mirrors the
            Visual Studio Installer pattern). The code-behind shrinks
            AppTitleBar's right margin so this whole area sits outside the drag
            region.
        -->
        <Border x:Name="ThemeToggleArea"
                Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal">
                <!--
                    Alert history bell — badge count shows unread alerts.
                    Opens a flyout with the full alert log.
                -->
                <Button x:Name="AlertBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <Grid>
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="14"
                                  Glyph="&#xE7E7;"/>
                        <Border x:Name="AlertBadge"
                                Background="#FFDC3545"
                                CornerRadius="7"
                                Width="14" Height="14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,4,8,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="AlertBadgeText"
                                       Text="0"
                                       FontSize="8"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="AlertFlyout"
                                Placement="Bottom"
                                Opening="AlertFlyout_Opening">
                            <StackPanel Width="340" Spacing="8">
                                <!-- Header -->
                                <Grid>
                                    <TextBlock Text="{x:Bind Lang.Ui_AlertHistory, Mode=OneWay}"
                                               FontWeight="SemiBold" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <Button x:Name="ClearAlertsBtn"
                                            HorizontalAlignment="Right"
                                            Content="{x:Bind Lang.Ui_ClearAlerts, Mode=OneWay}"
                                            Click="ClearAlerts_Click"
                                            Padding="10,4"
                                            FontSize="11"/>
                                </Grid>

                                <!-- Alert list -->
                                <ListView x:Name="AlertListView"
                                          Height="160"
                                          SelectionMode="None"
                                          ItemsSource="{x:Bind AlertHistory}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:AlertRecord">
                                            <Grid ColumnSpacing="8" Padding="0,4,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Severity icon -->
                                                <FontIcon Grid.Column="0"
                                                          FontFamily="Segoe MDL2 Assets"
                                                          Glyph="{x:Bind SeverityIcon}"
                                                          FontSize="13"
                                                          Foreground="{x:Bind SeverityColorBrush}"
                                                          VerticalAlignment="Top"
                                                          Margin="0,2,0,0"/>
                                                <!-- Content -->
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{x:Bind Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"/>
                                                    <TextBlock Text="{x:Bind Body}"
                                                               FontSize="11"
                                                               Opacity="0.7"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{x:Bind TimeText}"
                                                               FontSize="10"
                                                               Opacity="0.5"
                                                               FontFamily="Consolas"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <!-- Empty state -->
                                <TextBlock x:Name="NoAlertsText"
                                           Text="{x:Bind Lang.Ui_NoAlerts, Mode=OneWay}"
                                           FontSize="12"
                                           Opacity="0.5"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,8"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!--
                    Serial channel picker — sits to the left of the language /
                    theme buttons. Opens a flyout where the user can pick the
                    COM port + baud rate and connect to the ESP32 without
                    leaving the current page. The small dot at the bottom-right
                    indicates live connection state.
                -->
                <Button x:Name="SerialBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <Grid>
                        <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  FontSize="14"
                                  Glyph="&#xE839;"/>
                        <Ellipse x:Name="SerialStatusDot"
                                 Width="6" Height="6"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom"
                                 Margin="0,0,10,6"/>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="SerialFlyout" Placement="Bottom">
                            <StackPanel Width="300" Spacing="10">
                                <TextBlock Text="{x:Bind Lang.Ui_SerialConnection, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="12"/>

                                <!-- Channel row + refresh -->
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              x:Name="CapSerialPort"
                                              FontSize="12"
                                              HorizontalAlignment="Stretch"
                                              PlaceholderText="{x:Bind Lang.Ctrl_PhScanning, Mode=OneWay}"/>
                                    <Button Grid.Column="1"
                                            x:Name="CapRefreshBtn"
                                            Padding="8,6"
                                            ToolTipService.ToolTip="{x:Bind Lang.Ctrl_Refresh, Mode=OneWay}"
                                            Click="CapRefresh_Click">
                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="12"/>
                                    </Button>
                                </Grid>

                                <!-- Bitrate row -->
                                <ComboBox x:Name="CapSerialBaud"
                                          FontSize="12"
                                          HorizontalAlignment="Stretch"/>

                                <!-- Connect / Disconnect -->
                                <Button x:Name="CapConnectBtn"
                                        FontSize="12"
                                        HorizontalAlignment="Stretch"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Click="CapConnectBtn_Click"
                                        Content="{x:Bind Lang.Ctrl_Connect, Mode=OneWay}"/>

                                <!-- Status -->
                                <TextBlock x:Name="CapConnStatus"
                                           FontSize="11" Opacity="0.7"
                                           TextWrapping="Wrap"
                                           Text="{x:Bind Lang.Ctrl_NotConnected, Mode=OneWay}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <Button x:Name="LangBtn"
                        Style="{StaticResource CaptionButtonStyle}">
                    <FontIcon FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE12B;"/>
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <RadioMenuFlyoutItem x:Name="LangItemId" FontSize="12" Text="Indonesia"  Tag="id" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemMs" FontSize="12" Text="Malay"      Tag="ms" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemEn" FontSize="12" Text="English"    Tag="en" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemNl" FontSize="12" Text="Nederlands" Tag="nl" GroupName="LangGroup" Click="LangItem_Click"/>
                            <RadioMenuFlyoutItem x:Name="LangItemZh" FontSize="12" Text="中文"        Tag="zh" GroupName="LangGroup" Click="LangItem_Click"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="ThemeBtn"
                        Style="{StaticResource CaptionButtonStyle}"
                        Click="ThemeBtn_Click">
                    <FontIcon x:Name="ThemeIcon"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              FontSize="14"
                              Glyph="&#xE706;"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ── Playback bar (Row 1, hidden when no file is loaded) ─────── -->
        <Border x:Name="PlaybackBar"
                Grid.Row="1"
                Padding="12,6,12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- transport buttons -->
                    <ColumnDefinition Width="*"/>       <!-- slider + labels -->
                    <ColumnDefinition Width="Auto"/>   <!-- close button -->
                </Grid.ColumnDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2"
                            VerticalAlignment="Center">
                    <Button x:Name="PbFirstBtn" Padding="8,6"
                            ToolTipService.ToolTip="First frame"
                            Click="PbFirst_Click">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE892;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PbPlayPauseBtn" Padding="10,6"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Play / Pause"
                            Click="PbPlayPause_Click">
                        <FontIcon x:Name="PbPlayPauseIcon"
                                  FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="14"/>
                    </Button>
                    <Button x:Name="PbLastBtn" Padding="8,6"
                            ToolTipService.ToolTip="Last frame"
                            Click="PbLast_Click">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE893;" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Scrub area: file name + frame counter + slider -->
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock x:Name="PbFileText"
                                   FontSize="10" FontWeight="SemiBold" Opacity="0.7"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PbFrameText"
                                   FontSize="10" Opacity="0.5" FontFamily="Consolas"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="PbSlider"
                            Minimum="0" Maximum="100" Value="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,-4,0,-6"
                            ValueChanged="PbSlider_ValueChanged"/>
                </StackPanel>

                <!-- Unload (close) button -->
                <Button Grid.Column="2" Padding="8,6"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Unload file and return to live mode"
                        Click="PbClose_Click">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BB;" FontSize="12"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Status bar (Row 2) ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                Padding="16,5"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DataSourceText, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Opacity="0.55" CharacterSpacing="80"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                           FontSize="12" Opacity="0.65"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="ClockText"
                           FontSize="12" Opacity="0.45"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid x:Name="TourOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Canvas.ZIndex="20">
            <Grid.Background>
                <AcrylicBrush TintColor="Black"
                              TintOpacity="0.55"
                              TintLuminosityOpacity="0.0"
                              AlwaysUseFallback="True"
                              FallbackColor="#8D000000"/>
            </Grid.Background>
            <Border x:Name="TourDialogCard"
                    Width="620"
                    MaxHeight="760"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TourDialogTitle"
                               Grid.Row="0"
                               Margin="30,28,30,12"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"/>

                    <ContentControl x:Name="TourContentHost"
                                    Grid.Row="1"
                                    Margin="30,0,30,0"
                                    HorizontalContentAlignment="Center"/>

                    <Border Grid.Row="2"
                            Padding="30,18"
                            BorderThickness="0,1,0,0"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="TourOpenControlPanelButton"
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    Click="TourOpenControlPanel_Click"/>
                            <Button x:Name="TourCloseButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    Click="TourClose_Click"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
