<Window
    x:Class="BMSMonitor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BMSMonitor"
    Title="BMS Monitor">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>   <!-- playback bar -->
            <RowDefinition Height="Auto"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard"     Tag="Dashboard"/>
                <NavigationViewItem Content="Cell View"     Tag="CellView"/>
                <NavigationViewItem Content="Control Panel" Tag="ControlPanel"/>
                <NavigationViewItem Content="Logging"       Tag="Logging"/>
                <NavigationViewItem Content="Playback"      Tag="Playback"/>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Padding="0"/>
        </NavigationView>

        <!--
            Invisible drag region — full width, IsHitTestVisible=False so NavView
            and the toggle below (in z-order) still receive pointer events.
        -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Height="32"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                IsHitTestVisible="False"/>

        <!--
            Theme toggle — sits inside the 32 px title-bar zone, immediately
            left of the caption buttons. No box around it. Code-behind shrinks
            AppTitleBar's right margin so this area is OUTSIDE the drag region,
            allowing normal XAML hit-testing without passthrough region tricks.
        -->
        <Border x:Name="ThemeToggleArea"
                Grid.Row="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Height="32"
                Padding="0,0,10,0">
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="DARK"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="100" Opacity="0.5"
                           VerticalAlignment="Center"/>
                <ToggleSwitch x:Name="ThemeSwitch"
                              OnContent="" OffContent=""
                              ToolTipService.ToolTip="Dark / Light"
                              Toggled="ThemeSwitch_Toggled"
                              MinWidth="0"
                              VerticalAlignment="Center"
                              Margin="0,-4,0,-4"/>
                <TextBlock Text="LIGHT"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="100" Opacity="0.5"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Playback bar (Row 1, hidden when no file is loaded) ─────── -->
        <Border x:Name="PlaybackBar"
                Grid.Row="1"
                Padding="12,6,12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                Visibility="Collapsed">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- transport buttons -->
                    <ColumnDefinition Width="*"/>       <!-- slider + labels -->
                    <ColumnDefinition Width="Auto"/>   <!-- close button -->
                </Grid.ColumnDefinitions>

                <!-- Transport buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2"
                            VerticalAlignment="Center">
                    <Button x:Name="PbFirstBtn" Content="⏮" FontSize="13" Padding="6,4"
                            ToolTipService.ToolTip="First frame"
                            Click="PbFirst_Click"/>
                    <Button x:Name="PbPlayPauseBtn" Content="▶" FontSize="13" Padding="8,4"
                            Style="{ThemeResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Play / Pause"
                            Click="PbPlayPause_Click"/>
                    <Button x:Name="PbLastBtn" Content="⏭" FontSize="13" Padding="6,4"
                            ToolTipService.ToolTip="Last frame"
                            Click="PbLast_Click"/>
                </StackPanel>

                <!-- Scrub area: file name + frame counter + slider -->
                <StackPanel Grid.Column="1" Spacing="0" VerticalAlignment="Center">
                    <Grid>
                        <TextBlock x:Name="PbFileText"
                                   FontSize="10" FontWeight="SemiBold" Opacity="0.7"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PbFrameText"
                                   FontSize="10" Opacity="0.5" FontFamily="Consolas"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <Slider x:Name="PbSlider"
                            Minimum="0" Maximum="100" Value="0"
                            HorizontalAlignment="Stretch"
                            Margin="0,-4,0,-6"
                            ValueChanged="PbSlider_ValueChanged"/>
                </StackPanel>

                <!-- Unload (close) button -->
                <Button Grid.Column="2" Content="✕" FontSize="11" Padding="7,4"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Unload file and return to live mode"
                        Click="PbClose_Click"/>
            </Grid>
        </Border>

        <!-- ── Status bar (Row 2) ─────────────────────────────────────── -->
        <Border Grid.Row="2"
                Padding="16,5"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.DataSourceText, Mode=OneWay}"
                           FontSize="11" FontWeight="SemiBold"
                           Opacity="0.55" CharacterSpacing="80"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                           FontSize="12" Opacity="0.65"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="ClockText"
                           FontSize="12" Opacity="0.45"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
